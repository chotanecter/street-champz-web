# StreetChampz API — environment
# Copy to .env for local dev; set these in Railway for production.

PORT=3000

# SurrealDB connection
SURREAL_URL=ws://127.0.0.1:8000/rpc
SURREAL_NS=streetchampz
SURREAL_DB=main
SURREAL_USER=root
SURREAL_PASS=root

# Auth — must match whatever issues the frontend's Bearer tokens
JWT_SECRET=change-me-to-a-long-random-string

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=https://streetchampz.com,http://localhost:5173
